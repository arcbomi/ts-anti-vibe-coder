# Copy this file to .env for local development.

# Shared
APP_ENV=development
ENV=dev
LOG_LEVEL=info
SWAGGER_ENABLED=true
DEV_SEED_USER_NAME=Student User
DEV_SEED_USER_EMAIL=student@example.com
DEV_SEED_USER_PASSWORD=correct-password

# MongoDB
MONGODB_PORT=27017
# For host-run scripts, use mongodb://localhost:27017
MONGODB_URI=mongodb://mongodb:27017
MONGODB_DATABASE=anti_vibe

# Redis / Queue
REDIS_PORT=6379
REDIS_URL=redis://redis:6379
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
QUEUE_URL=redis://redis:6379
QUEUE_NAMESPACE=anti_vibe
ANALYSIS_QUEUE_NAME=analysis_jobs
ANALYSIS_DEAD_LETTER_QUEUE_NAME=analysis_jobs_dead
REPO_DOWNLOAD_QUEUE_NAME=repo_download_jobs
REPO_DOWNLOAD_DEAD_LETTER_QUEUE_NAME=repo_download_jobs_dead
KAFKA_PORT=9092
KAFKA_BROKERS=redpanda:9092

# Gitea Bot (server-side)
GITEA_BASE_URL=https://gitea.com
GITEA_BOT_TOKEN=replace_me
GITEA_BOT_USERNAME=gitea-server-userbot

# AI (OpenAI-compatible HTTP API)
AI_BASE_URL=https://api.openai.com
AI_API_KEY=replace_me
AI_MODEL=gpt-4.1-mini
AI_TIMEOUT_SECONDS=60

# Auth / internal service tokens (replace in deployed environments)
AUTH_JWT_HS256_SECRET=local-dev-jwt-secret-change-me
JWT_SECRET=local-dev-jwt-secret-change-me
JWT_ACCESS_TOKEN_TTL_MINUTES=60
JWT_REFRESH_TOKEN_TTL_DAYS=30
INTERNAL_SERVICE_TOKEN=local-internal-token
EXAM_SERVICE_INTERNAL_TOKEN=local-internal-token
TOMORROW_BASE_URL=https://01.tomorrow-school.ai
TOMORROW_SERVICE_URL=http://tomorrow-service:3001
TOMORROW_USERNAME=dmukhat
TOMORROW_PASSWORD=change-me
TOMORROW_AUTH_ENDPOINT=
TOMORROW_REFERRER=
TOMORROW_X_JWT_TOKEN=undefined
TOMORROW_SESSION_ID=
TOMORROW_PROFILE_PATH=/intra/astanahub/profile?event=96
RUN_TOMORROW_INTEGRATION=false

# Exam policy
EXAM_TIMEZONE=Asia/Shanghai
EXAM_OPEN_DOW=Friday
EXAM_PASS_PERCENT=70
REPO_STORAGE_ROOT=data/repos
REPO_CLONE_TIMEOUT_SECONDS=60

# Service ports
API_GATEWAY_PORT=8080
AUTH_SERVICE_PORT=3005
USER_SERVICE_PORT=3002
GITEA_READER_SERVICE_HTTP_PORT=8082
GITEA_SERVICE_PORT=8082
AI_ANALYSIS_SERVICE_HTTP_PORT=8083
EXAM_SERVICE_PORT=3006
SCHEDULER_SERVICE_HTTP_PORT=8086
TOMORROW_SERVICE_PORT=3001
WORKER_SERVICE_PORT=3007
FRONTEND_PORT=5173

# Internal service URLs used by Docker Compose
AUTH_SERVICE_BASE_URL=http://auth-service:3005
USER_SERVICE_URL=http://user-service:3002
GITEA_READER_SERVICE_BASE_URL=http://gitea-service:8082
QUESTION_SERVICE_BASE_URL=http://exam-service:3006/api/v1
EXAM_SERVICE_BASE_URL=http://exam-service:3006/api/v1

# Frontend
VITE_API_BASE_URL=http://localhost:8080

# Worker queue settings
WORKER_CONCURRENCY=3
MAX_JOB_ATTEMPTS=3
RETRY_DELAY_SECONDS=30

# Auth integration settings
AUTH_CREDENTIAL_SECRET=local-dev-jwt-secret-change-me
TOMORROW_SCHOOL_AUTH_ENDPOINT=https://01.tomorrow-school.ai/api/auth/signin
TOMORROW_SCHOOL_AUTH_TIMEOUT_SECONDS=10
TOMORROW_SCHOOL_AUTH_REFERRER=
TOMORROW_SCHOOL_AUTH_X_JWT_TOKEN=undefined
TOMORROW_SCHOOL_AUTH_SESSION_ID=
TOMORROW_SCHOOL_GRAPHQL_ENDPOINT=
TOMORROW_SCHOOL_GRAPHQL_ROLE=user

# Integration test targets
TEST_REDIS_ADDR=localhost:6379

# Smoke test targets
SMOKE_FRONTEND_URL=http://localhost:5173
SMOKE_API_GATEWAY_URL=http://localhost:8080
SMOKE_AUTH_SERVICE_URL=http://localhost:3005
SMOKE_GITEA_READER_SERVICE_URL=http://localhost:8082
SMOKE_AI_ANALYSIS_SERVICE_URL=http://localhost:8083
SMOKE_QUESTION_SERVICE_URL=http://localhost:3006/api/v1
SMOKE_EXAM_SERVICE_URL=http://localhost:3006/api/v1
SMOKE_SCHEDULER_SERVICE_URL=http://localhost:8086
SMOKE_WORKER_SERVICE_URL=http://localhost:3007
