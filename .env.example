# Shared
ENV=dev
LOG_LEVEL=info

# Postgres
POSTGRES_DSN=postgres://postgres:postgres@localhost:5432/anti_vibe?sslmode=disable

# Redis / Queue
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
QUEUE_NAMESPACE=anti_vibe

# GitLab Bot (server-side)
GITLAB_BASE_URL=https://gitlab.com
GITLAB_BOT_TOKEN=replace_me
GITLAB_BOT_USERNAME=replace_me

# AI (OpenAI-compatible HTTP API)
AI_BASE_URL=https://api.openai.com
AI_API_KEY=replace_me
AI_MODEL=gpt-4.1-mini
AI_TIMEOUT_SECONDS=60

# Exam policy
EXAM_TIMEZONE=Asia/Shanghai
EXAM_OPEN_DOW=Saturday
EXAM_PASS_PERCENT=70

# Service ports (prefixed overrides; services fall back to HTTP_PORT)
API_GATEWAY_HTTP_PORT=8080
AUTH_SERVICE_HTTP_PORT=8081
GITLAB_READER_SERVICE_HTTP_PORT=8082
AI_ANALYSIS_SERVICE_HTTP_PORT=8083
QUESTION_SERVICE_HTTP_PORT=8084
EXAM_SERVICE_HTTP_PORT=8085
SCHEDULER_SERVICE_HTTP_PORT=8086
WORKER_SERVICE_HTTP_PORT=8087

# JWT (MVP)
AUTH_JWT_HS256_SECRET=replace_me

# Worker queue settings
QUEUE_URL=redis://localhost:6379
ANALYSIS_QUEUE_NAME=analysis_jobs
ANALYSIS_DEAD_LETTER_QUEUE_NAME=analysis_jobs_dead
WORKER_CONCURRENCY=3
MAX_JOB_ATTEMPTS=3
RETRY_DELAY_SECONDS=30
DATABASE_URL=postgres://postgres:postgres@localhost:5432/anti_vibe?sslmode=disable

# Smoke test targets
SMOKE_FRONTEND_URL=http://localhost:5173
SMOKE_API_GATEWAY_URL=http://localhost:8080
SMOKE_AUTH_SERVICE_URL=http://localhost:8081
SMOKE_GITLAB_READER_SERVICE_URL=http://localhost:8082
SMOKE_AI_ANALYSIS_SERVICE_URL=http://localhost:8083
SMOKE_QUESTION_SERVICE_URL=http://localhost:8084
SMOKE_EXAM_SERVICE_URL=http://localhost:8085
SMOKE_SCHEDULER_SERVICE_URL=http://localhost:8086
SMOKE_WORKER_SERVICE_URL=http://localhost:8087
